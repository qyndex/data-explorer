# Data Explorer — environment variables
# Copy to .env and fill in values before running

# Server
PORT=8000
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins
# Dev defaults: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Maximum file upload size in megabytes (default: 50)
MAX_UPLOAD_MB=50

# Supported file extensions (comma-separated, no dots)
# Default: csv,json
ALLOWED_EXTENSIONS=csv,json
